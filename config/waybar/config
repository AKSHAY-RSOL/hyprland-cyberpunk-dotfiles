    "mod": "dock",
    "exclusive": true,
    "passthrough": false,
    "gtk-layer-shell": true,
    "height": 40,
    "modules-left": [
        "hyprland/workspaces",
        "clock"
    ],
    "modules-center": [
        "custom/media"
    ],
    "modules-right": [
